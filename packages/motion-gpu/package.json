{
	"name": "@motion-core/motion-gpu",
	"version": "0.4.0",
	"description": "Framework-agnostic WebGPU runtime for fullscreen WGSL shaders with explicit Svelte and React adapter entrypoints.",
	"keywords": [
		"svelte",
		"svelte5",
		"react",
		"react18",
		"webgpu",
		"wgsl",
		"shader",
		"graphics",
		"gpu",
		"postprocessing"
	],
	"homepage": "https://github.com/Motion-Core/motion-gpu/tree/master/packages/motion-gpu#readme",
	"bugs": {
		"url": "https://github.com/Motion-Core/motion-gpu/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Motion-Core/motion-gpu.git",
		"directory": "packages/motion-gpu"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./advanced": {
			"types": "./dist/advanced.d.ts",
			"default": "./dist/advanced.js"
		},
		"./svelte": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"default": "./dist/svelte/index.js"
		},
		"./svelte/advanced": {
			"types": "./dist/svelte/advanced.d.ts",
			"svelte": "./dist/svelte/advanced.js",
			"default": "./dist/svelte/advanced.js"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"default": "./dist/react/index.js"
		},
		"./react/advanced": {
			"types": "./dist/react/advanced.d.ts",
			"default": "./dist/react/advanced.js"
		},
		"./core": {
			"types": "./dist/core/index.d.ts",
			"default": "./dist/core/index.js"
		},
		"./core/advanced": {
			"types": "./dist/core/advanced.d.ts",
			"default": "./dist/core/advanced.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "svelte-package -i src/lib -o dist && node ./scripts/build/transpile-react-tsx.mjs && node ./scripts/build/patch-webgpu-types-dts.mjs",
		"build:watch": "svelte-package -i src/lib -o dist -w --preserve-output",
		"prepack": "bun run build",
		"check": "svelte-check --tsconfig ./tsconfig.json && publint",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"e2e:serve": "vite --config e2e/vite.config.ts",
		"e2e:serve:svelte": "MOTION_GPU_E2E_FRAMEWORK=svelte vite --config e2e/vite.config.ts",
		"e2e:serve:react": "MOTION_GPU_E2E_FRAMEWORK=react vite --config e2e/vite.config.ts",
		"perf:core": "bun run ./scripts/perf/core-benchmark.ts",
		"perf:core:check": "bun run ./scripts/perf/core-benchmark.ts --strict",
		"perf:core:baseline": "bun run ./scripts/perf/core-benchmark.ts --update-baseline",
		"perf:runtime": "bun run ./scripts/perf/runtime-benchmark.ts",
		"perf:runtime:check": "bun run ./scripts/perf/runtime-benchmark.ts --strict",
		"perf:runtime:baseline": "bun run ./scripts/perf/runtime-benchmark.ts --update-baseline",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0",
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"svelte": {
			"optional": true
		}
	},
	"dependencies": {
		"@webgpu/types": "^0.1.66"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/package": "^2.5.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/react": "^16.3.0",
		"@testing-library/svelte": "^5.2.8",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@vitest/coverage-v8": "^4.0.18",
		"@types/node": "^25.3.3",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"happy-dom": "^20.0.10",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.15",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
